# ci-test-build.yml.template
# CI パイプライン: lint → test → build
#
# 前提条件:
#   - package.json に以下のスクリプトが定義されていること:
#     "lint": "eslint ." または "biome check ."
#     "test": "jest" または "vitest run"
#     "build": "next build" または "tsc" 等
#     "typecheck": "tsc --noEmit"（任意）
#
# カスタマイズ箇所:
#   - {PACKAGE_MANAGER}: npm / pnpm / yarn
#   - {LOCK_FILE}: package-lock.json / pnpm-lock.yaml / yarn.lock
#   - {NODE_VERSION}: 20 / 22 等
#   - {MAIN_BRANCH}: main / master

name: CI

on:
  push:
    branches:
      - main
      - develop
  pull_request:
    branches:
      - main
      - develop

# デフォルト権限を最小化
permissions:
  contents: read

jobs:
  # ============================================================
  # Job 1: lint（コードスタイル・静的解析）
  # ============================================================
  lint:
    name: Lint
    runs-on: ubuntu-latest

    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Setup Node.js
        uses: actions/setup-node@v4
        with:
          node-version: '{NODE_VERSION}'
          cache: '{PACKAGE_MANAGER}'
          cache-dependency-path: '{LOCK_FILE}'

      - name: Install dependencies
        run: {PACKAGE_MANAGER} install --frozen-lockfile
        # npm の場合: npm ci
        # yarn の場合: yarn install --immutable

      - name: Run lint
        run: {PACKAGE_MANAGER} run lint

      - name: Type check
        run: {PACKAGE_MANAGER} run typecheck
        # typecheck スクリプトがない場合は削除またはコメントアウト

  # ============================================================
  # Job 2: test（ユニットテスト・インテグレーションテスト）
  # ============================================================
  test:
    name: Test
    runs-on: ubuntu-latest

    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Setup Node.js
        uses: actions/setup-node@v4
        with:
          node-version: '{NODE_VERSION}'
          cache: '{PACKAGE_MANAGER}'
          cache-dependency-path: '{LOCK_FILE}'

      - name: Install dependencies
        run: {PACKAGE_MANAGER} install --frozen-lockfile

      - name: Run tests
        run: {PACKAGE_MANAGER} run test
        env:
          CI: true
          # テストで必要な環境変数を追加
          # NODE_ENV: test

      - name: Upload coverage report
        if: always()
        uses: actions/upload-artifact@v4
        with:
          name: coverage-report
          path: coverage/
          retention-days: 7
        # coverage ディレクトリが存在しない場合は削除

  # ============================================================
  # Job 3: build（本番ビルド検証）
  # ============================================================
  build:
    name: Build
    runs-on: ubuntu-latest
    needs: [lint, test]  # lint と test が通過した場合のみ実行

    outputs:
      image-tag: ${{ steps.meta.outputs.version }}
      # Docker イメージを使用しない場合はこのセクションを削除

    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Setup Node.js
        uses: actions/setup-node@v4
        with:
          node-version: '{NODE_VERSION}'
          cache: '{PACKAGE_MANAGER}'
          cache-dependency-path: '{LOCK_FILE}'

      - name: Install dependencies
        run: {PACKAGE_MANAGER} install --frozen-lockfile

      - name: Build
        run: {PACKAGE_MANAGER} run build
        env:
          NODE_ENV: production
          # ビルドで必要な環境変数を追加

      - name: Upload build artifacts
        uses: actions/upload-artifact@v4
        with:
          name: build-output
          path: |
            .next/
            dist/
            out/
          # ビルド出力ディレクトリをプロジェクトに合わせて変更
          retention-days: 1
          if-no-files-found: warn

